{
  "version": "1.0.0",
  "title": "Pad Voice",
  "description": "A slow, sustained pad with a soft lowpass body and gentle LFO motion in the filter.",
  "modules": [
    {
      "id": "osc",
      "type": "oscillator",
      "config": {
        "oscillator_type": "sawtooth"
      }
    },
    {
      "id": "motion_lfo",
      "type": "lfo",
      "config": {
        "frequency": 0.18,
        "waveform": "sine"
      }
    },
    {
      "id": "filter",
      "type": "filter",
      "config": {
        "filter_type": "lowpass",
        "cutoff": 1500.0,
        "resonance": 0.18,
        "cv_amount": 1600.0
      }
    },
    {
      "id": "env",
      "type": "adsr",
      "config": {
        "attack": 0.65,
        "decay": 1.8,
        "sustain": 0.78,
        "release": 8
      }
    },
    {
      "id": "vca",
      "type": "vca"
    }
  ],
  "connections": [
    {
      "from": "motion_lfo",
      "from_port": "out_uni",
      "to": "filter",
      "to_port": "cutoff_cv"
    },
    {
      "from": "osc",
      "from_port": "audio",
      "to": "filter",
      "to_port": "audio"
    },
    {
      "from": "filter",
      "from_port": "audio",
      "to": "vca",
      "to_port": "audio"
    },
    {
      "from": "env",
      "from_port": "envelope",
      "to": "vca",
      "to_port": "cv"
    }
  ],
  "inputs": [
    {
      "name": "frequency",
      "to": "osc",
      "to_port": "frequency"
    },
    {
      "name": "gate",
      "to": "env",
      "to_port": "gate"
    }
  ],
  "outputs": [
    {
      "name": "audio",
      "from": "vca",
      "from_port": "audio"
    }
  ],
  "controls": [
    {
      "key": "attack",
      "module": "env",
      "control": "attack"
    },
    {
      "key": "release",
      "module": "env",
      "control": "release"
    },
    {
      "key": "warmth",
      "module": "filter",
      "control": "cutoff"
    },
    {
      "key": "motion",
      "module": "motion_lfo",
      "control": "frequency"
    }
  ]
}
