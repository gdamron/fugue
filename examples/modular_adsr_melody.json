{
  "version": "1.0.0",
  "title": "Dorian Melody with ADSR Envelope",
  "description": "Demonstrates modular routing with clock → melody → oscillator → VCA with ADSR envelope control",
  "modules": [
    {
      "id": "clock",
      "type": "clock",
      "config": {
        "bpm": 60.0,
        "time_signature": {
          "beats_per_measure": 4,
          "beat_unit": 4
        }
      }
    },
    {
      "id": "melody",
      "type": "melody",
      "config": {
        "root_note": 60,
        "scale_degrees": [0, 2, 3, 5, 7, 9, 10],
        "note_weights": [1.0, 0.5, 1.0, 0.5, 1.5, 0.5, 1.0]
      }
    },
    {
      "id": "osc",
      "type": "oscillator",
      "config": {
        "oscillator_type": "sawtooth"
      }
    },
    {
      "id": "adsr",
      "type": "adsr",
      "config": {
        "attack": 0.05,
        "decay": 0.1,
        "sustain": 0.6,
        "release": 0.8
      }
    },
    {
      "id": "vca",
      "type": "vca"
    },
    {
      "id": "reverb",
      "type": "reverb",
      "config": {
        "room_size": 0.8,
        "damping": 0.4,
        "wet": 0.5,
        "dry": 0.2
      }
    },
    {
      "id": "dac",
      "type": "dac"
    }
  ],
  "connections": [
    {
      "from": "clock",
      "from_port": "gate",
      "to": "melody",
      "to_port": "gate"
    },
    {
      "from": "melody",
      "from_port": "frequency",
      "to": "osc",
      "to_port": "frequency"
    },
    {
      "from": "melody",
      "from_port": "gate",
      "to": "adsr",
      "to_port": "gate"
    },
    {
      "from": "osc",
      "from_port": "audio",
      "to": "vca",
      "to_port": "audio"
    },
    {
      "from": "adsr",
      "from_port": "envelope",
      "to": "vca",
      "to_port": "cv"
    },
    {
      "from": "vca",
      "from_port": "audio",
      "to": "reverb",
      "to_port": "left"
    },
    {
      "from": "vca",
      "from_port": "audio",
      "to": "reverb",
      "to_port": "right"
    },
    {
      "from": "reverb",
      "from_port": "left",
      "to": "dac",
      "to_port": "audio_left"
    },
    {
      "from": "reverb",
      "from_port": "right",
      "to": "dac",
      "to_port": "audio_right"
    }
  ]
}
