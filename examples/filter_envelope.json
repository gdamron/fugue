{
  "version": "1.0.0",
  "title": "Filter Envelope Sweep",
  "description": "Classic subtractive synthesis - sawtooth through resonant low-pass filter with envelope modulation",
  "modules": [
    {
      "id": "clock",
      "type": "clock",
      "config": {
        "bpm": 110.0,
        "time_signature": {
          "beats_per_measure": 4,
          "beat_unit": 4
        }
      }
    },
    {
      "id": "melody",
      "type": "melody",
      "config": {
        "root_note": 36,
        "scale_degrees": [0, 3, 5, 8, 12],
        "note_weights": [1.5, 0.8, 1.0, 1.0, 0.6]
      }
    },
    {
      "id": "osc",
      "type": "oscillator",
      "config": {
        "oscillator_type": "sawtooth"
      }
    },
    {
      "id": "filter",
      "type": "filter",
      "config": {
        "filter_type": "lowpass",
        "cutoff": 200.0,
        "resonance": 0.6,
        "cv_amount": 4000.0
      }
    },
    {
      "id": "filter_env",
      "type": "adsr",
      "config": {
        "attack": 0.01,
        "decay": 0.4,
        "sustain": 0.1,
        "release": 0.3
      }
    },
    {
      "id": "amp_env",
      "type": "adsr",
      "config": {
        "attack": 0.005,
        "decay": 0.1,
        "sustain": 0.7,
        "release": 0.4
      }
    },
    {
      "id": "vca",
      "type": "vca"
    },
    {
      "id": "dac",
      "type": "dac"
    }
  ],
  "connections": [
    {
      "from": "clock",
      "from_port": "gate",
      "to": "melody",
      "to_port": "gate"
    },
    {
      "from": "melody",
      "from_port": "frequency",
      "to": "osc",
      "to_port": "frequency"
    },
    {
      "from": "melody",
      "from_port": "gate",
      "to": "filter_env",
      "to_port": "gate"
    },
    {
      "from": "melody",
      "from_port": "gate",
      "to": "amp_env",
      "to_port": "gate"
    },
    {
      "from": "osc",
      "from_port": "audio",
      "to": "filter",
      "to_port": "audio"
    },
    {
      "from": "filter_env",
      "from_port": "envelope",
      "to": "filter",
      "to_port": "cutoff_cv"
    },
    {
      "from": "filter",
      "from_port": "audio",
      "to": "vca",
      "to_port": "audio"
    },
    {
      "from": "amp_env",
      "from_port": "envelope",
      "to": "vca",
      "to_port": "cv"
    },
    {
      "from": "vca",
      "from_port": "audio",
      "to": "dac",
      "to_port": "audio"
    }
  ]
}
