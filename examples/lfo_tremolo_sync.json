{
  "version": "1.0.0",
  "title": "LFO Tremolo with Sync",
  "description": "Demonstrates synced LFO for rhythmic tremolo - triangle LFO resets on each note for consistent amplitude pulsing",
  "modules": [
    {
      "id": "clock",
      "type": "clock",
      "config": {
        "bpm": 100.0,
        "time_signature": {
          "beats_per_measure": 4,
          "beat_unit": 4
        }
      }
    },
    {
      "id": "melody",
      "type": "melody",
      "config": {
        "root_note": 48,
        "scale_degrees": [0, 1, 5, 7, 8, 12],
        "note_weights": [1.5, 0.8, 1.0, 0.5, 1.0, 0.8]
      }
    },
    {
      "id": "tremolo_lfo",
      "type": "lfo",
      "config": {
        "frequency": 8.0,
        "waveform": "triangle"
      }
    },
    {
      "id": "osc",
      "type": "oscillator",
      "config": {
        "oscillator_type": "square",
        "am_amount": 0.6
      }
    },
    {
      "id": "adsr",
      "type": "adsr",
      "config": {
        "attack": 0.01,
        "decay": 0.1,
        "sustain": 0.8,
        "release": 0.4
      }
    },
    {
      "id": "vca",
      "type": "vca"
    },
    {
      "id": "dac",
      "type": "dac"
    }
  ],
  "connections": [
    {
      "from": "clock",
      "from_port": "gate",
      "to": "melody",
      "to_port": "gate"
    },
    {
      "from": "melody",
      "from_port": "gate",
      "to": "tremolo_lfo",
      "to_port": "sync"
    },
    {
      "from": "melody",
      "from_port": "frequency",
      "to": "osc",
      "to_port": "frequency"
    },
    {
      "from": "tremolo_lfo",
      "from_port": "out",
      "to": "osc",
      "to_port": "am"
    },
    {
      "from": "melody",
      "from_port": "gate",
      "to": "adsr",
      "to_port": "gate"
    },
    {
      "from": "osc",
      "from_port": "audio",
      "to": "vca",
      "to_port": "audio"
    },
    {
      "from": "adsr",
      "from_port": "envelope",
      "to": "vca",
      "to_port": "cv"
    },
    {
      "from": "vca",
      "from_port": "audio",
      "to": "dac",
      "to_port": "audio"
    }
  ]
}
