{
  "version": "1.0.0",
  "title": "In C \u2014 Terry Riley (1964)",
  "description": "13-voice generative performance of Terry Riley's *In C*. Each voice owns a cell_sequencer loaded with the 53-cell score and a code module that decides when to advance. A constant C5 8th-note pulse anchors the ensemble. Mixed across a 20-channel mixer through a shared reverb. The conductor agent module is included but disabled by default \u2014 see the README to wire it up.",
  "assets": {
    "score": {
      "path": "in_c/score.json"
    },
    "voice_progression": {
      "path": "in_c/voice_progression.js"
    },
    "conductor_prompt": {
      "path": "in_c/conductor.md"
    }
  },
  "developments": [
    {
      "name": "piano_voice",
      "path": "developments/piano.json"
    },
    {
      "name": "marimba_voice",
      "path": "developments/marimba.json"
    },
    {
      "name": "vibraphone_voice",
      "path": "developments/vibraphone.json"
    },
    {
      "name": "pluck_voice",
      "path": "developments/pluck.json"
    },
    {
