{
  "version": "1.0.0",
  "title": "Fast Minor Arpeggio",
  "description": "A rapid arpeggiated pattern in Aeolian (natural minor) mode with square wave",
  "modules": [
    {
      "id": "clock",
      "type": "clock",
      "config": {
        "bpm": 140.0,
        "time_signature": {
          "beats_per_measure": 4,
          "beat_unit": 4
        }
      }
    },
    {
      "id": "melody",
      "type": "melody",
      "config": {
        "root_note": 57,
        "mode": "aeolian",
        "scale_degrees": [0, 2, 4],
        "note_weights": [1.5, 1.0, 1.5],
        "note_duration": 0.25,
        "oscillator_type": "square"
      }
    },
    {
      "id": "voice",
      "type": "voice",
      "config": {
        "oscillator_type": "square"
      }
    },
    {
      "id": "dac",
      "type": "dac",
      "config": {}
    }
  ],
  "connections": [
    {
      "from": "clock",
      "to": "melody"
    },
    {
      "from": "melody",
      "to": "voice"
    },
    {
      "from": "voice",
      "to": "dac"
    }
  ]
}
