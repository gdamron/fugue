{
  "version": "1.0.0",
  "title": "LFO Vibrato Melody",
  "description": "Demonstrates LFO modulation for vibrato effect - sine LFO modulates oscillator pitch",
  "modules": [
    {
      "id": "clock",
      "type": "clock",
      "config": {
        "bpm": 80.0,
        "time_signature": {
          "beats_per_measure": 4,
          "beat_unit": 4
        }
      }
    },
    {
      "id": "melody",
      "type": "melody",
      "config": {
        "root_note": 60,
        "mode": "lydian",
        "scale_degrees": [0, 2, 4, 6, 7],
        "note_weights": [1.5, 1.0, 1.0, 0.5, 1.0]
      }
    },
    {
      "id": "vibrato_lfo",
      "type": "lfo",
      "config": {
        "frequency": 5.5,
        "waveform": "sine"
      }
    },
    {
      "id": "osc",
      "type": "oscillator",
      "config": {
        "oscillator_type": "sawtooth",
        "fm_amount": 8.0
      }
    },
    {
      "id": "adsr",
      "type": "adsr",
      "config": {
        "attack": 0.1,
        "decay": 0.15,
        "sustain": 0.6,
        "release": 0.5
      }
    },
    {
      "id": "vca",
      "type": "vca"
    },
    {
      "id": "dac",
      "type": "dac"
    }
  ],
  "connections": [
    {
      "from": "clock",
      "from_port": "gate",
      "to": "melody",
      "to_port": "gate"
    },
    {
      "from": "melody",
      "from_port": "frequency",
      "to": "osc",
      "to_port": "frequency"
    },
    {
      "from": "vibrato_lfo",
      "from_port": "out",
      "to": "osc",
      "to_port": "fm"
    },
    {
      "from": "melody",
      "from_port": "gate",
      "to": "adsr",
      "to_port": "gate"
    },
    {
      "from": "osc",
      "from_port": "audio",
      "to": "vca",
      "to_port": "audio"
    },
    {
      "from": "adsr",
      "from_port": "envelope",
      "to": "vca",
      "to_port": "cv"
    },
    {
      "from": "vca",
      "from_port": "audio",
      "to": "dac",
      "to_port": "audio"
    }
  ]
}
