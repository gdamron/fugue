{
  "mcpServers": {
    "fugue": {
      "command": "cargo",
      "args": [
        "run",
        "--release",
        "--features",
        "mcp",
        "--bin",
        "fugue-mcp"
      ],
      "cwd": "${workspaceFolder}"
    },
    "fugue-dev": {
      "command": "cargo",
      "args": [
        "run",
        "--features",
        "dev",
        "--bin",
        "fugue-mcp-dev"
      ],
      "cwd": "${workspaceFolder}"
    }
  }
}
