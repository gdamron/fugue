{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "fugue": {
      "type": "local",
      "command": [
        "cargo",
        "run",
        "--features",
        "mcp",
        "--release",
        "--bin",
        "fugue-mcp"
      ],
    },
    "fugue-dev": {
      "type": "local",
      "command": [
        "cargo",
        "run",
        "--features",
        "dev",
        "--bin",
        "fugue-mcp-dev"
      ],
    },
  },
}
